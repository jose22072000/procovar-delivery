generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  role         String        @default("admin")
  createdAt    DateTime      @default(now())
  orders       Order[]
  routes       Route[]
  vehicles     Vehicle[]
  savedOrigins SavedOrigin[]
  branchId     String?
  branch       Branch?       @relation("UserBranch", fields: [branchId], references: [id])
  createdBranches Branch[]    @relation("BranchCreator")
  products     Product[]
}

model Product {
  id              String   @id @default(cuid())
  name            String
  weight          Float    @default(0)
  packaging       String?
  unitsPerPackage Float?
  category        String?
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  lat       Float
  lng       Float
  areaKm2   Float    @default(1)
  creatorId String
  creator   User     @relation("BranchCreator", fields: [creatorId], references: [id])
  members   User[]   @relation("UserBranch")
  createdAt DateTime @default(now())
}

model SavedOrigin {
  id        String   @id @default(cuid())
  name      String
  address   String
  lat       Float
  lng       Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Vehicle {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("truck")
  plate     String?
  capacity  Float    @default(1000)
  status    String   @default("available")
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  routes    Route[]
  orders    Order[]
  orderAssignments OrderVehicle[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String    @id @default(cuid())
  operationNumber String?
  customerName    String
  address         String
  endAddress      String?
  endLat          Float?
  endLng          Float?
  lat             Float?
  lng             Float?
  weight          Float     @default(1)
  status          String    @default("pending")
  tripLeg         String    @default("outbound")
  notes           String?
  routeId         String?
  route           Route?    @relation(fields: [routeId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id])
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  price           Float?
  segmentKm       Float?
  // Itemized breakdown of what to deliver to this client: [{ description, quantity }]
  items           Json      @default("[]")
  vehicleAssignments OrderVehicle[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  stopOrder       Int?
  deliveredAt     DateTime?
}

model OrderVehicle {
  id        String   @id @default(cuid())
  orderId   String
  vehicleId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([orderId, vehicleId])
}

model Route {
  id              String   @id @default(cuid())
  name            String?
  routeCode       String?
  status          String   @default("planned")
  originAddress   String?
  originLat       Float?
  originLng       Float?
  totalDistance   Float    @default(0)
  totalWeight     Float    @default(0)
  totalPrice      Float    @default(0)
  deliveryDate    DateTime?
  orders          Order[]
  vehicleId       String?
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  optimized       Boolean  @default(false)
}

model Settings {
  id        String @id @default(cuid())
  baseFee   Float  @default(5.0)
  costPerKm Float  @default(1.5)
  costPerKg Float  @default(0.5)
  currency  String @default("USD")
  cupRate   Float  @default(320.0)
  cupRateUpdatedAt DateTime @default(now())
  // Display currencies relative to USD (base = 1). Array of { code, rate } where
  // rate = units of this currency per 1 USD. e.g. [{"code":"CUP","rate":320}]
  currencies Json @default("[]")
}
